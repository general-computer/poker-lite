# Apache caching rules for Poker Lite static deployment.
# Place this in the same directory as index.html, bundle.js, and style.css.

<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — short cache (may change with new builds)
  ExpiresByType text/html "access plus 1 hour"

  # CSS and JS — immutable since filenames include content hashes or build artifacts
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"

  # Source maps — same as the JS they accompany
  ExpiresByType application/json "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  # Security headers
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"

  # Allow cross-origin access to source maps for browser DevTools
  <FilesMatch "\.map$">
    Header always set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
